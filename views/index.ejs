    {_id:'bk1',customerName:'Nguyễn Văn A',carNumber:'51B-67890',startDate:'2026-03-01T08:00',endDate:'2026-03-05T08:00',returnDate:null,extraCharge:0,totalAmount:3600000},
    {_id:'bk2',customerName:'Trần Thị B',carNumber:'51A-12345',startDate:'2026-03-06T10:00',endDate:'2026-03-08T10:00',returnDate:'2026-03-09T12:00',extraCharge:600000,totalAmount:1800000},
    {_id:'bk3',customerName:'Lê Minh Tuấn',carNumber:'51F-44444',startDate:'2026-02-20T09:00',endDate:'2026-02-25T09:00',returnDate:'2026-02-25T09:00',extraCharge:0,totalAmount:3500000},
