<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CarRent Pro — Hệ Thống Quản Lý Cho Thuê Xe</title>
  <style>
    /* Fallback font stack - không cần Google Fonts */
    :root {
      --font-display: 'Trebuchet MS', 'Segoe UI', system-ui, -apple-system, sans-serif;
      --font-body: 'Segoe UI', system-ui, -apple-system, 'Helvetica Neue', Arial, sans-serif;
    }
  </style>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#08090d;--surface:#0f1117;--surface2:#161920;--surface3:#1d2028;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);
  --accent:#e8ff47;--accent2:#3b82f6;--text:#eef0f4;--muted:#5a6070;
  --green:#22c55e;--orange:#f97316;--red:#ef4444;--purple:#a855f7;
  --sw:240px;
}
body{font-family:var(--font-body);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* ═══ SIDEBAR ═══ */
.sidebar{
  position:fixed;top:0;left:0;width:var(--sw);height:100vh;
  background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;padding:24px 16px;z-index:200;overflow-y:auto;
}
.logo{display:flex;align-items:center;gap:10px;margin-bottom:36px;padding:0 6px}
.logo-mark{width:40px;height:40px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.logo-mark i{color:#000;font-size:1em}
.logo-text{font-family:var(--font-display);font-weight:800;font-size:1.1em;letter-spacing:-0.01em;white-space:nowrap;line-height:1.2}
.logo-text b{color:var(--accent)}

.nav-section{font-size:0.62em;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);padding:0 10px;margin:20px 0 8px}
.nav-item{
  display:flex;align-items:center;gap:11px;padding:11px 12px;border-radius:9px;
  cursor:pointer;color:var(--muted);font-size:0.9em;font-weight:500;
  transition:all .18s ease;margin-bottom:2px;border:1px solid transparent;user-select:none;
}
.nav-item i{width:17px;text-align:center;font-size:0.9em}
.nav-item:hover{color:var(--text);background:var(--surface2)}
.nav-item.active{color:#000;background:var(--accent);border-color:var(--accent)}
.nav-item.active i{color:#000}

.sidebar-clock{margin-top:auto;padding:16px;border-radius:12px;background:var(--surface2);border:1px solid var(--border)}
.clock-time{font-family:var(--font-display);font-size:1.45em;font-weight:800;letter-spacing:0}
.clock-date{font-size:0.75em;color:var(--muted);margin-top:3px}

/* ═══ MAIN ═══ */
.main{margin-left:var(--sw);min-height:100vh}
.topbar{
  position:sticky;top:0;z-index:100;
  background:rgba(8,9,13,.88);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);
  border-bottom:1px solid var(--border);padding:16px 36px;
  display:flex;align-items:center;justify-content:space-between;
}
.topbar-title{font-family:var(--font-display);font-size:1.35em;font-weight:800}
.topbar-sub{font-size:0.78em;color:var(--muted)}

/* ═══ BUTTONS ═══ */
.btn{
  display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:8px;
  font-size:0.86em;font-weight:600;cursor:pointer;border:none;
  transition:all .18s ease;font-family:var(--font-body);white-space:nowrap;
}
.btn-primary{background:var(--accent);color:#000}
.btn-primary:hover{background:#d6ec30;transform:translateY(-1px);box-shadow:0 4px 16px rgba(232,255,71,.25)}
.btn-ghost{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
.btn-ghost:hover{border-color:var(--border2);background:var(--surface3)}
.btn-danger{background:rgba(239,68,68,.12);color:var(--red);border:1px solid rgba(239,68,68,.25)}
.btn-danger:hover{background:var(--red);color:#fff;border-color:var(--red)}
.btn-warn{background:rgba(249,115,22,.12);color:var(--orange);border:1px solid rgba(249,115,22,.25)}
.btn-warn:hover{background:var(--orange);color:#fff;border-color:var(--orange)}
.btn-sm{padding:6px 13px;font-size:0.8em}
.btn-icon{padding:7px;width:32px;height:32px;justify-content:center;border-radius:7px}

/* ═══ PAGE ═══ */
.page{display:none;padding:32px 36px;animation:fadeUp .28s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* ═══ STATS ═══ */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:36px}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:22px;position:relative;overflow:hidden;transition:border-color .2s}
.stat:hover{border-color:var(--border2)}
.stat::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.stat.s1::after{background:var(--accent)}.stat.s2::after{background:var(--accent2)}
.stat.s3::after{background:var(--green)}.stat.s4::after{background:var(--purple)}
.stat-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.stat-ico{width:40px;height:40px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1em}
.ic-y{background:rgba(232,255,71,.1);color:var(--accent)}
.ic-b{background:rgba(59,130,246,.1);color:var(--accent2)}
.ic-g{background:rgba(34,197,94,.1);color:var(--green)}
.ic-p{background:rgba(168,85,247,.1);color:var(--purple)}
.stat-num{font-family:var(--font-display);font-size:2em;font-weight:800;line-height:1}
.stat-lbl{font-size:0.78em;color:var(--muted);margin-top:5px}

/* ═══ SEC HEADER ═══ */
.sec-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px}
.sec-title{font-family:var(--font-display);font-size:1.15em;font-weight:800}
.sec-sub{font-size:0.78em;color:var(--muted);margin-top:2px}

/* ═══ CAR CARDS ═══ */
.fleet-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:18px}
.car-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:all .22s ease}
.car-card:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.45)}
.car-visual{height:160px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.car-visual.sedan{background:linear-gradient(135deg,#161d2e,#1f2d4a)}
.car-visual.suv{background:linear-gradient(135deg,#1c1430,#2a1a47)}
.car-visual.luxury{background:linear-gradient(135deg,#151e15,#1e2e1e)}
.car-visual.sports{background:linear-gradient(135deg,#2a1010,#3d1515)}
.car-visual.van{background:linear-gradient(135deg,#0f1e28,#142433)}
.car-emo{font-size:5em;filter:drop-shadow(0 6px 20px rgba(0,0,0,.6));transition:transform .3s ease}
.car-card:hover .car-emo{transform:scale(1.1) translateY(-4px)}
.car-status-badge{position:absolute;top:12px;right:12px;font-size:0.68em;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:4px 10px;border-radius:20px}
.bs-available{background:rgba(34,197,94,.2);color:var(--green);border:1px solid rgba(34,197,94,.35)}
.bs-rented{background:rgba(249,115,22,.2);color:var(--orange);border:1px solid rgba(249,115,22,.35)}
.bs-maintenance{background:rgba(239,68,68,.2);color:var(--red);border:1px solid rgba(239,68,68,.35)}
.car-body{padding:18px}
.car-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px}
.car-name{font-family:var(--font-display);font-size:1em;font-weight:700}
.car-plate{font-size:0.72em;font-weight:600;letter-spacing:.05em;background:var(--surface3);border:1px solid var(--border);padding:3px 8px;border-radius:5px;color:var(--muted)}
.car-specs{display:flex;gap:0;margin:14px 0;padding:12px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.spec-item{flex:1;text-align:center}
.spec-item+.spec-item{border-left:1px solid var(--border)}
.spec-v{font-size:0.9em;font-weight:700;color:var(--text)}
.spec-k{font-size:0.67em;color:var(--muted);margin-top:2px}
.car-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:14px;min-height:22px}
.tag{font-size:0.67em;padding:3px 8px;border-radius:20px;background:var(--surface2);border:1px solid var(--border);color:var(--muted)}
.car-foot{display:flex;justify-content:space-between;align-items:center}
.car-price{font-family:var(--font-display);font-weight:800;font-size:1.1em}
.car-price small{font-size:0.6em;color:var(--muted);font-family:var(--font-body);font-weight:400}
.car-btns{display:flex;gap:6px}

/* ═══ TABLE ═══ */
.tbl-wrap{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.tbl-top{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.tbl-top-title{font-family:var(--font-display);font-size:0.95em;font-weight:700}
table{width:100%;border-collapse:collapse}
thead th{padding:12px 18px;text-align:left;font-size:0.69em;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border);background:var(--surface2)}
tbody td{padding:13px 18px;border-bottom:1px solid var(--border);font-size:0.87em;vertical-align:middle}
tbody tr:last-child td{border-bottom:none}
tbody tr{transition:background .15s}
tbody tr:hover td{background:rgba(255,255,255,.02)}

/* ═══ MODAL ═══ */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.72);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:500;align-items:center;justify-content:center;padding:20px}
.overlay.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:18px;padding:32px;width:100%;max-width:560px;max-height:92vh;overflow-y:auto;animation:fadeUp .22s ease}
.modal.wide{max-width:660px}
.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:26px}
.modal-head h2{font-family:var(--font-display);font-size:1.2em;font-weight:800}
.modal-close{width:32px;height:32px;background:var(--surface2);border:1px solid var(--border);border-radius:7px;cursor:pointer;color:var(--muted);font-size:1em;display:flex;align-items:center;justify-content:center;transition:all .15s}
.modal-close:hover{color:var(--text);border-color:var(--border2)}

.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-group{margin-bottom:16px}
label{display:block;font-size:0.72em;font-weight:700;color:var(--muted);margin-bottom:7px;letter-spacing:.05em;text-transform:uppercase}
input,select,textarea{width:100%;padding:10px 13px;background:var(--surface2);border:1px solid var(--border);border-radius:9px;color:var(--text);font-size:0.9em;font-family:var(--font-body);transition:border-color .18s}
input:focus,select:focus,textarea:focus{outline:none;border-color:rgba(232,255,71,.5);background:var(--surface3)}
input::placeholder,textarea::placeholder{color:var(--muted)}
select option{background:var(--surface3)}
textarea{resize:vertical;min-height:80px}
input[disabled]{opacity:.45;cursor:not-allowed}
.form-actions{display:flex;gap:10px;margin-top:22px;padding-top:18px;border-top:1px solid var(--border)}
.msg{margin-top:12px;padding:11px 15px;border-radius:8px;font-size:0.84em;display:none}
.msg.show{display:block}
.msg.ok{background:rgba(34,197,94,.12);color:var(--green);border:1px solid rgba(34,197,94,.25)}
.msg.err{background:rgba(239,68,68,.12);color:var(--red);border:1px solid rgba(239,68,68,.25)}

/* ═══ CONFIRM DIALOG ═══ */
#cf-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(10px);z-index:800;align-items:center;justify-content:center}
#cf-overlay.open{display:flex}
.cf-box{background:var(--surface);border:1px solid var(--border2);border-radius:16px;padding:30px;width:90%;max-width:380px;text-align:center;animation:fadeUp .2s ease}
.cf-icon{font-size:2.8em;margin-bottom:12px}
.cf-title{font-family:var(--font-display);font-size:1.1em;font-weight:800;margin-bottom:8px}
.cf-text{font-size:0.84em;color:var(--muted);line-height:1.6;margin-bottom:22px}
.cf-btns{display:flex;gap:10px;justify-content:center}

/* ═══ TOAST ═══ */
#toast-wrap{position:fixed;bottom:24px;right:24px;z-index:900;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:var(--surface);border:1px solid var(--border2);border-radius:11px;padding:13px 18px;font-size:0.87em;font-weight:500;min-width:270px;box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;align-items:center;gap:10px;animation:slideIn .3s ease}
@keyframes slideIn{from{transform:translateX(120%);opacity:0}to{transform:translateX(0);opacity:1}}
.toast.ok{border-left:3px solid var(--green)}.toast.ok i{color:var(--green)}
.toast.err{border-left:3px solid var(--red)}.toast.err i{color:var(--red)}

/* ═══ REPORTS ═══ */
.report-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.report-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px}
.report-card h4{font-family:var(--font-display);font-weight:800;margin-bottom:6px;font-size:1em}
.report-card p{font-size:0.8em;color:var(--muted);line-height:1.6;margin-bottom:16px}
.prog-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px}
.prog-label{font-size:0.8em;color:var(--muted)}
.prog-val{font-size:0.8em;font-weight:700}
.prog-bar{height:5px;background:var(--surface2);border-radius:3px;margin-bottom:12px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;transition:width .7s ease}

/* ═══ INFO BOX ═══ */
.info-box{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:12px 14px;font-size:0.82em;color:var(--muted);margin-bottom:4px;display:flex;align-items:flex-start;gap:8px}

/* ═══ EMPTY ═══ */
.empty{text-align:center;padding:52px 20px;color:var(--muted)}
.empty i{font-size:2.8em;margin-bottom:14px;opacity:.2;display:block}
.empty p{font-size:0.88em}

::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* ═══ LOGIN PAGE ═══ */
#login-screen{display:flex;position:fixed;inset:0;z-index:1000;background:var(--bg);align-items:center;justify-content:center}
#login-screen.hidden{display:none}
.login-box{background:var(--surface);border:1px solid var(--border2);border-radius:20px;padding:40px;width:100%;max-width:420px;animation:fadeUp .3s ease}
.login-logo{display:flex;align-items:center;gap:12px;margin-bottom:32px;justify-content:center}
.login-logo-mark{width:48px;height:48px;background:var(--accent);border-radius:12px;display:flex;align-items:center;justify-content:center}
.login-logo-mark i{color:#000;font-size:1.2em}
.login-title{font-family:var(--font-display);font-size:1.4em;font-weight:800}
.login-title b{color:var(--accent)}
.login-sub{text-align:center;font-size:.82em;color:var(--muted);margin-bottom:28px}
.login-footer{margin-top:20px;text-align:center;font-size:.75em;color:var(--muted)}
/* ═══ TOPBAR USER ═══ */
.topbar-user{display:flex;align-items:center;gap:10px}
.user-badge{display:flex;align-items:center;gap:8px;padding:7px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:9px;font-size:.84em}
.role-tag{font-size:.7em;padding:2px 7px;border-radius:20px;font-weight:700}
.role-admin{background:rgba(232,255,71,.15);color:var(--accent)}
.role-staff{background:rgba(59,130,246,.15);color:var(--accent2)}
</style>
</head>
<body>

<!-- ══ LOGIN SCREEN ══ -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">
      <div class="login-logo-mark"><i class="fas fa-car"></i></div>
      <div class="login-title">Car<b>Rent</b> Pro</div>
    </div>
    <div class="login-sub">Đăng nhập để quản lý hệ thống cho thuê xe</div>
    <div class="form-group"><label>Username</label><input id="lg-user" placeholder="admin" autocomplete="username"></div>
    <div class="form-group"><label>Password</label><input id="lg-pass" type="password" placeholder="••••••••" autocomplete="current-password"></div>
    <div class="form-actions" style="margin-top:8px;padding-top:0;border-top:none">
      <button class="btn btn-primary" style="width:100%;justify-content:center" onclick="doLogin()">
        <i class="fas fa-right-to-bracket"></i> Đăng Nhập
      </button>
    </div>
    <div class="msg" id="msg-login"></div>
    <div class="login-footer">Tài khoản mặc định: <strong>admin</strong> / <strong>admin123</strong></div>
  </div>
</div>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-mark"><i class="fas fa-car"></i></div>
    <div class="logo-text" style="white-space:nowrap">Car<b>Rent</b> Pro</div>
  </div>
  <div class="nav-section">Tổng quan</div>
  <div class="nav-item active" data-page="dashboard" onclick="goPage('dashboard',this)">
    <i class="fas fa-chart-line"></i> Dashboard
  </div>
  <div class="nav-section">Quản lý</div>
  <div class="nav-item" data-page="fleet" onclick="goPage('fleet',this)">
    <i class="fas fa-car-side"></i> Quản Lý Xe
  </div>
  <div class="nav-item" data-page="bookings" onclick="goPage('bookings',this)">
    <i class="fas fa-calendar-check"></i> Đơn Đặt Xe
  </div>
  <div class="nav-section">Phân tích</div>
  <div class="nav-item" data-page="reports" onclick="goPage('reports',this)">
    <i class="fas fa-chart-mixed"></i> Báo Cáo
  </div>
  <div class="sidebar-clock">
    <div class="clock-time" id="clock">--:--</div>
    <div class="clock-date" id="clkdate">--</div>
  </div>
</aside>

<!-- ══ MAIN ══ -->
<main class="main">
  <div class="topbar">
    <div>
      <div class="topbar-title" id="pg-title">Dashboard</div>
      <div class="topbar-sub" id="pg-sub">Xin chào, hôm nay là ngày tốt để kinh doanh 🚗</div>
    </div>
    <div class="topbar-user">
      <div class="user-badge">
        <i class="fas fa-user-circle"></i>
        <span id="topbar-username">—</span>
        <span class="role-tag" id="topbar-role"></span>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="doLogout()"><i class="fas fa-right-from-bracket"></i> Đăng xuất</button>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div class="page active" id="page-dashboard">
    <div class="stats-row">
      <div class="stat s1"><div class="stat-head"><div class="stat-ico ic-y"><i class="fas fa-car"></i></div></div><div class="stat-num" id="st-total">0</div><div class="stat-lbl">Tổng số xe</div></div>
      <div class="stat s2"><div class="stat-head"><div class="stat-ico ic-b"><i class="fas fa-calendar-check"></i></div></div><div class="stat-num" id="st-bookings">0</div><div class="stat-lbl">Tổng đơn đặt</div></div>
      <div class="stat s3"><div class="stat-head"><div class="stat-ico ic-g"><i class="fas fa-circle-check"></i></div></div><div class="stat-num" id="st-avail">0</div><div class="stat-lbl">Xe sẵn có</div></div>
      <div class="stat s4"><div class="stat-head"><div class="stat-ico ic-p"><i class="fas fa-coins"></i></div></div><div class="stat-num" id="st-revenue" style="font-size:1.1em">₫0</div><div class="stat-lbl">Tổng doanh thu</div></div>
    </div>
    <div class="sec-head">
      <div><div class="sec-title">Xe nổi bật</div><div class="sec-sub">3 xe gần nhất trong đội</div></div>
      <button class="btn btn-ghost btn-sm" onclick="goPage('fleet',document.querySelector('[data-page=fleet]'))">Xem tất cả <i class="fas fa-arrow-right"></i></button>
    </div>
    <div class="fleet-grid" id="dash-fleet"></div>
  </div>

  <!-- FLEET -->
  <div class="page" id="page-fleet">
    <div class="sec-head">
      <div><div class="sec-title">Đội Xe</div><div class="sec-sub" id="fleet-sub">Đang tải...</div></div>
      <button class="btn btn-primary" onclick="openAddCar()"><i class="fas fa-plus"></i> Thêm Xe Mới</button>
    </div>
    <div class="fleet-grid" id="fleet-grid"></div>
  </div>

  <!-- BOOKINGS -->
  <div class="page" id="page-bookings">
    <div class="sec-head">
