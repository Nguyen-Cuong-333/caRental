<script>
// ══ AUTH STATE ══
let AUTH = { token: null, user: null };

function getToken()  { return AUTH.token || localStorage.getItem('cr_token'); }
function getUser()   { try { return AUTH.user || JSON.parse(localStorage.getItem('cr_user')); } catch(e){ return null; } }
function saveAuth(token, user) {
  AUTH.token = token; AUTH.user = user;
  localStorage.setItem('cr_token', token);
  localStorage.setItem('cr_user', JSON.stringify(user));
}
function clearAuth() {
  AUTH = { token: null, user: null };
  localStorage.removeItem('cr_token');
  localStorage.removeItem('cr_user');
}

// ── Kiểm tra login khi tải trang ──
window.addEventListener('DOMContentLoaded', () => {
  const token = getToken();
  const user  = getUser();
  if (token && user) {
    showApp(user);
  } else {
    showLoginScreen();
  }
  // Attach date change listeners
  ['ab-start','ab-end'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('change', updateCostPreview);
  });
});

function showLoginScreen() {
  document.getElementById('login-screen').classList.remove('hidden');
}
function showApp(user) {
  document.getElementById('login-screen').classList.add('hidden');
  document.getElementById('topbar-username').textContent = user.username;
  const roleEl = document.getElementById('topbar-role');
  roleEl.textContent = user.role === 'admin' ? 'Admin' : 'Staff';
  roleEl.className = 'role-tag ' + (user.role === 'admin' ? 'role-admin' : 'role-staff');
  loadDashboard();
}

// ── Đăng nhập ──
async function doLogin() {
  const username = document.getElementById('lg-user').value.trim();
  const password = document.getElementById('lg-pass').value;
  if (!username || !password) { setMsg('msg-login','⚠️ Nhập đầy đủ username và password',false); return; }
  try {
    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password })
    });
    const d = await res.json();
    if (d.success) {
      saveAuth(d.token, d.user);
      showApp(d.user);
      document.getElementById('lg-pass').value = '';
    } else {
      setMsg('msg-login', '❌ ' + d.message, false);
    }
  } catch(e) {
    setMsg('msg-login', '❌ Không kết nối được server', false);
  }
}
// Cho phép nhấn Enter để login
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !document.getElementById('login-screen').classList.contains('hidden')) {
    doLogin();
  }
});

// ── Đăng xuất ──
function doLogout() {
  clearAuth();
  showLoginScreen();
  toast('Đã đăng xuất thành công.');
}
// ══ LOCAL DATA STORE ══
let DB = {
  cars: [
    {carNumber:'51A-12345',capacity:5,status:'available',pricePerDay:600000,features:['Tự động','Điều hoà','GPS'],type:'sedan'},
    {carNumber:'51B-67890',capacity:7,status:'rented',pricePerDay:900000,features:['Tự động','Camera 360°','Cửa điện'],type:'suv'},
    {carNumber:'51C-11111',capacity:4,status:'available',pricePerDay:2000000,features:['Tự động','Da thật','Panoramic','HUD'],type:'luxury'},
    {carNumber:'51D-22222',capacity:2,status:'maintenance',pricePerDay:1500000,features:['Tự động','Turbo','Sport Mode'],type:'sports'},
