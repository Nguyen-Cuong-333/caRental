// ══ FORM HELPERS ══
function v(id){return document.getElementById(id).value;}
function setMsg(id,text,ok){const el=document.getElementById(id);el.textContent=text;el.className='msg show '+(ok?'ok':'err');}

// ══ API — tự động gắn JWT ══
async function apiCall(method, path, body=null){
  const token = getToken();
  const opts = {
    method,
    headers: {
      'Content-Type': 'application/json',
      ...(token ? { 'Authorization': 'Bearer ' + token } : {})
    }
  };
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(path, opts);
  // Token hết hạn → tự logout
  if (r.status === 401 || r.status === 403) {
    const d = await r.json();
    // Chỉ logout nếu là lỗi token (không phải lỗi phân quyền tính năng)
    if (d.message && (d.message.includes('token') || d.message.includes('đăng nhập'))) {
      toast('Phiên đăng nhập hết hạn. Vui lòng đăng nhập lại.', 'err');
      clearAuth(); showLoginScreen();
    }
    return d;
  }
  return r.json();
}

// ══ DATA ══
async function getCars(){
  try{const d=await apiCall('GET','/api/cars');if(d.success&&d.data){DB.cars=d.data;DB.useApi=true;return d.data;}}catch(e){}
  return DB.cars;
}
async function getBookings(){
  try{const d=await apiCall('GET','/api/bookings');if(d.success&&d.data){DB.bookings=d.data;return d.data;}}catch(e){}
  return DB.bookings;
}

// ══ CAR MAPS ══
const CE={sedan:'🚗',suv:'🚙',luxury:'🏎️',sports:'🏎️',van:'🚐'};
const CN={sedan:'Sedan',suv:'SUV Cao Cấp',luxury:'Luxury Premium',sports:'Sports Car',van:'Van / Minibus'};
const SL={available:'Sẵn Có',rented:'Đang Thuê',maintenance:'Bảo Trì'};
const SC={available:'bs-available',rented:'bs-rented',maintenance:'bs-maintenance'};

function carCard(car,btns=true){
  const t=car.type||'sedan';
  const tags=(car.features||[]).slice(0,3).map(f=>`<span class="tag">${f}</span>`).join('');
  const bHTML=btns?`<div class="car-btns">
    <button class="btn btn-warn btn-icon" title="Sửa xe" onclick="event.stopPropagation();openEditCar('${car.carNumber}')"><i class="fas fa-pen"></i></button>
    <button class="btn btn-danger btn-icon" title="Xóa xe" onclick="event.stopPropagation();deleteCar('${car.carNumber}')"><i class="fas fa-trash"></i></button>
  </div>`:'';
  return `<div class="car-card">
    <div class="car-visual ${t}">
      <div class="car-emo">${CE[t]||'🚗'}</div>
      <div class="car-status-badge ${SC[car.status]||'bs-available'}">${SL[car.status]||car.status}</div>
    </div>
    <div class="car-body">
      <div class="car-top"><div class="car-name">${CN[t]||t}</div><div class="car-plate">${car.carNumber}</div></div>
      <div class="car-specs">
        <div class="spec-item"><div class="spec-v">${car.capacity}</div><div class="spec-k">Chỗ ngồi</div></div>
        <div class="spec-item"><div class="spec-v">${(car.pricePerDay/1000).toFixed(0)}K</div><div class="spec-k">₫/ngày</div></div>
        <div class="spec-item"><div class="spec-v">2024</div><div class="spec-k">Năm SX</div></div>
      </div>
      <div class="car-tags">${tags||'<span class="tag" style="opacity:.4">Chưa có tính năng</span>'}</div>
      <div class="car-foot"><div class="car-price">₫${car.pricePerDay.toLocaleString('vi-VN')}<small>/ngày</small></div>${bHTML}</div>
    </div>
  </div>`;
}

// ══ DASHBOARD ══
async function loadDashboard(){
  const [cars,bookings]=await Promise.all([getCars(),getBookings()]);
  document.getElementById('st-total').textContent=cars.length;
  document.getElementById('st-bookings').textContent=bookings.length;
  document.getElementById('st-avail').textContent=cars.filter(c=>c.status==='available').length;
  const rev=bookings.reduce((s,b)=>s+(b.totalAmount||0),0);
  document.getElementById('st-revenue').textContent='₫'+fmtShort(rev);
  const g=document.getElementById('dash-fleet');
  if(!cars.length){g.innerHTML='<div class="empty" style="grid-column:1/-1"><i class="fas fa-car-side"></i><p>Chưa có xe nào</p></div>';return;}
  g.innerHTML=cars.slice(0,3).map(c=>carCard(c,false)).join('');
}

// ══ FLEET ══
async function loadFleet(){
  const cars=await getCars();
  document.getElementById('fleet-sub').textContent=`${cars.length} xe trong đội · ${cars.filter(c=>c.status==='available').length} sẵn sàng`;
  const g=document.getElementById('fleet-grid');
  if(!cars.length){g.innerHTML='<div class="empty" style="grid-column:1/-1"><i class="fas fa-inbox"></i><p>Chưa có xe. Nhấn "Thêm Xe Mới" để bắt đầu.</p></div>';return;}
  g.innerHTML=cars.map(c=>carCard(c,true)).join('');
}

// ══ THÊM XE ══
function openAddCar(){
  ['ac-plate','ac-seats','ac-price','ac-features'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('ac-status').value='available';
  document.getElementById('ac-type').value='sedan';
  openOv('ov-addcar');
}
async function saveCar(){
  const plate=v('ac-plate').trim(), seats=parseInt(v('ac-seats')), price=parseFloat(v('ac-price'));
  if(!plate){setMsg('msg-addcar','⚠️ Vui lòng nhập biển số xe',false);return;}
  if(!seats||seats<1){setMsg('msg-addcar','⚠️ Số chỗ ngồi không hợp lệ',false);return;}
  if(!price||price<0){setMsg('msg-addcar','⚠️ Giá thuê không hợp lệ',false);return;}
  const car={carNumber:plate,capacity:seats,pricePerDay:price,status:v('ac-status'),type:v('ac-type'),features:v('ac-features').split(',').map(s=>s.trim()).filter(Boolean)};
  try{
    const d=await apiCall('POST','/api/cars',car);
    if(d.success){toast('Đã thêm xe '+plate+' thành công!');closeOv('ov-addcar');loadFleet();loadDashboard();return;}
    setMsg('msg-addcar','❌ '+d.message,false);return;
  }catch(e){}
  if(DB.cars.find(c=>c.carNumber===plate)){setMsg('msg-addcar','⚠️ Biển số xe đã tồn tại',false);return;}
  DB.cars.push(car);
  toast('Đã thêm xe '+plate+' thành công!');
  closeOv('ov-addcar');loadFleet();loadDashboard();
}

// ══ SỬA XE ══
async function openEditCar(plate){
  let car=DB.cars.find(c=>c.carNumber===plate);
  try{const d=await apiCall('GET','/api/cars/'+plate);if(d.success)car=d.data;}catch(e){}
  if(!car){toast('Không tìm thấy xe','err');return;}
  document.getElementById('ec-plate').value=car.carNumber;
  document.getElementById('ec-seats').value=car.capacity;
  document.getElementById('ec-price').value=car.pricePerDay;
  document.getElementById('ec-status').value=car.status;
  document.getElementById('ec-type').value=car.type||'sedan';
  document.getElementById('ec-features').value=(car.features||[]).join(', ');
  openOv('ov-editcar');
}
async function updateCar(){
  const plate=v('ec-plate');
  const seats=parseInt(v('ec-seats')), price=parseFloat(v('ec-price'));
  if(!seats||seats<1){setMsg('msg-editcar','⚠️ Số chỗ ngồi không hợp lệ',false);return;}
  if(!price||price<0){setMsg('msg-editcar','⚠️ Giá thuê không hợp lệ',false);return;}
  const data={capacity:seats,pricePerDay:price,status:v('ec-status'),type:v('ec-type'),features:v('ec-features').split(',').map(s=>s.trim()).filter(Boolean)};
  try{
    const d=await apiCall('PUT','/api/cars/'+plate,data);
    if(d.success){toast('Đã cập nhật xe '+plate);closeOv('ov-editcar');loadFleet();loadDashboard();return;}
    setMsg('msg-editcar','❌ '+d.message,false);return;
  }catch(e){}
  const idx=DB.cars.findIndex(c=>c.carNumber===plate);
  if(idx>=0) DB.cars[idx]={...DB.cars[idx],...data};
  toast('Đã cập nhật xe '+plate);
  closeOv('ov-editcar');loadFleet();loadDashboard();
}

// ══ XÓA XE ══
async function deleteCar(plate){
  const ok=await confirm2('Xóa Xe','Xóa xe '+plate+'? Hành động này không thể hoàn tác.','🗑️','Xóa Xe','btn-danger');
  if(!ok)return;
  try{
    const d=await apiCall('DELETE','/api/cars/'+plate);
    if(d.success){toast('Đã xóa xe '+plate);loadFleet();loadDashboard();return;}
    toast('Lỗi: '+d.message,'err');return;
  }catch(e){}
  DB.cars=DB.cars.filter(c=>c.carNumber!==plate);
  toast('Đã xóa xe '+plate);loadFleet();loadDashboard();
}

// ══ LOAD BOOKINGS ══
async function loadBookings(){
  const bookings=await getBookings();
  document.getElementById('bk-sub').textContent=`${bookings.length} đơn đặt trong hệ thống`;
  const tbody=document.getElementById('bk-tbody');
  if(!bookings.length){
    tbody.innerHTML='<tr><td colspan="9"><div class="empty"><i class="fas fa-inbox"></i><p>Chưa có đơn đặt xe nào. Nhấn "Tạo Đơn Đặt" để bắt đầu.</p></div></td></tr>';
    return;
  }
  tbody.innerHTML=bookings.map((b,i)=>{
    const sd=fmtDate(b.startDate), ed=fmtDate(b.endDate);
    const rd=b.returnDate?`<span style="color:var(--green)">${fmtDate(b.returnDate)}</span>`:'<span style="color:var(--muted)">—</span>';
    const ec=(b.extraCharge&&b.extraCharge>0)?`<span style="color:var(--orange);font-weight:600">₫${b.extraCharge.toLocaleString('vi-VN')}</span>`:'<span style="color:var(--muted)">₫0</span>';
    return `<tr>
      <td style="color:var(--muted);font-size:.8em">${i+1}</td>
      <td><strong>${b.customerName}</strong></td>
      <td><span class="car-plate" style="display:inline-block">${b.carNumber}</span></td>
      <td style="font-size:.85em">${sd}</td><td style="font-size:.85em">${ed}</td><td style="font-size:.85em">${rd}</td>
      <td>${ec}</td>
      <td><strong style="color:var(--accent2)">₫${(b.totalAmount||0).toLocaleString('vi-VN')}</strong></td>
      <td><div style="display:flex;gap:6px">
        <button class="btn btn-warn btn-icon btn-sm" title="Sửa đơn / Trả xe" onclick="openEditBooking('${b._id}')"><i class="fas fa-pen"></i></button>
        <button class="btn btn-danger btn-icon btn-sm" title="Xóa đơn" onclick="deleteBooking('${b._id}')"><i class="fas fa-trash"></i></button>
      </div></td>
    </tr>`;
  }).join('');
}

// ══ TẠO ĐƠN ĐẶT ══
let _abSelectedCar = null;

async function openAddBooking(){
  _abSelectedCar = null;
  ['ab-name','ab-start','ab-end'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('ab-plate').value='';
  document.getElementById('ab-car-preview').style.display='none';
  document.getElementById('ab-cost-preview').style.display='none';

  // Load available cars as selectable cards
  const cars = await getCars();
  const avail = cars.filter(c=>c.status==='available');
  const list = document.getElementById('ab-car-list');
  if(!avail.length){
    list.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:20px;color:var(--muted);font-size:.85em"><i class="fas fa-ban" style="display:block;font-size:2em;margin-bottom:8px;opacity:.3"></i>Không có xe sẵn sàng để đặt</div>';
  } else {
    list.innerHTML = avail.map(car=>{
      const t=car.type||'sedan';
      const emo={sedan:'🚗',suv:'🚙',luxury:'🏎️',sports:'🏎️',van:'🚐'}[t]||'🚗';
      const nm={sedan:'Sedan',suv:'SUV',luxury:'Luxury',sports:'Sports',van:'Van'}[t]||t;
      return `<div class="ab-car-option" data-plate="${car.carNumber}" onclick="selectCar('${car.carNumber}')"
        style="border:1px solid var(--border);border-radius:10px;padding:12px;cursor:pointer;transition:all .18s;background:var(--surface2)">
        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-size:1.8em;line-height:1">${emo}</span>
          <div style="flex:1;min-width:0">
            <div style="font-family:var(--font-display);font-weight:700;font-size:.88em">${nm}</div>
            <div style="font-size:.72em;color:var(--muted)">${car.carNumber} · ${car.capacity} chỗ</div>
            <div style="font-size:.78em;color:var(--accent);font-weight:600;margin-top:2px">₫${car.pricePerDay.toLocaleString('vi-VN')}/ngày</div>
          </div>
        </div>
      </div>`;
    }).join('');
  }
  openOv('ov-addbooking');
}

function selectCar(plate){
  const cars = DB.cars;
  const car = cars.find(c=>c.carNumber===plate);
  if(!car) return;
  _abSelectedCar = car;
  document.getElementById('ab-plate').value = plate;

  // Highlight selected card
  document.querySelectorAll('.ab-car-option').forEach(el=>{
    const isMe = el.dataset.plate===plate;
    el.style.border = isMe ? '1px solid var(--accent)' : '1px solid var(--border)';
    el.style.background = isMe ? 'rgba(232,255,71,.08)' : 'var(--surface2)';
  });

  // Show preview
  const t=car.type||'sedan';
  const emo={sedan:'🚗',suv:'🚙',luxury:'🏎️',sports:'🏎️',van:'🚐'}[t]||'🚗';
  const nm={sedan:'Sedan',suv:'SUV Cao Cấp',luxury:'Luxury Premium',sports:'Sports Car',van:'Van / Minibus'}[t]||t;
  document.getElementById('ab-prev-emo').textContent=emo;
  document.getElementById('ab-prev-name').textContent=nm;
  document.getElementById('ab-prev-plate').textContent='Biển số: '+plate+' · '+car.capacity+' chỗ ngồi';
  document.getElementById('ab-prev-price').textContent='₫'+car.pricePerDay.toLocaleString('vi-VN')+' / ngày';
  document.getElementById('ab-car-preview').style.display='block';
  updateCostPreview();
}

function updateCostPreview(){
  if(!_abSelectedCar) return;
  const start=document.getElementById('ab-start').value;
  const end=document.getElementById('ab-end').value;
  if(!start||!end||new Date(end)<=new Date(start)){
    document.getElementById('ab-cost-preview').style.display='none'; return;
  }
  const days=Math.max(1,Math.ceil((new Date(end)-new Date(start))/86400000));
  const total=_abSelectedCar.pricePerDay*days;
  document.getElementById('ab-cost-detail').textContent=days+' ngày × ₫'+_abSelectedCar.pricePerDay.toLocaleString('vi-VN');
  document.getElementById('ab-cost-total').textContent='₫'+total.toLocaleString('vi-VN');
  document.getElementById('ab-cost-preview').style.display='block';
}

// Attach live update on date change — handled in auth DOMContentLoaded above

async function saveBooking(){
  const name=v('ab-name').trim(), plate=v('ab-plate').trim();
  const start=v('ab-start'), end=v('ab-end');
  if(!name){setMsg('msg-addbooking','⚠️ Vui lòng nhập tên khách hàng',false);return;}
  if(!plate){setMsg('msg-addbooking','⚠️ Vui lòng chọn xe từ danh sách phía trên',false);return;}
  if(!start||!end){setMsg('msg-addbooking','⚠️ Vui lòng chọn ngày bắt đầu và kết thúc',false);return;}
  if(new Date(end)<=new Date(start)){setMsg('msg-addbooking','⚠️ Ngày kết thúc phải sau ngày bắt đầu',false);return;}
  const body={customerName:name,carNumber:plate,startDate:new Date(start).toISOString(),endDate:new Date(end).toISOString()};
  // -- Thử gọi API trước --
  try{
    const d=await apiCall('POST','/api/bookings',body);
    if(d.success){
      const days=d.data?.rentalDays||1, amt=d.data?.totalAmount||0;
      toast(`Đặt xe thành công! ${days} ngày — ₫${amt.toLocaleString('vi-VN')}`);
      closeOv('ov-addbooking');loadBookings();loadDashboard();return;
    }
    // API trả lỗi rõ ràng (xe không tồn tại, xe đang thuê, v.v.)
    setMsg('msg-addbooking','❌ '+d.message,false);return;
  }catch(e){
    // Mất kết nối API → fallback local
  }
  // -- Fallback local: lấy xe từ API hoặc DB local --
  let car=null;
  try{const dc=await apiCall('GET','/api/cars/'+plate);if(dc.success)car=dc.data;}catch(e){}
  if(!car) car=DB.cars.find(c=>c.carNumber===plate);
  if(!car){setMsg('msg-addbooking','❌ Không tìm thấy xe biển số "'+plate+'". Vui lòng kiểm tra lại.','err');return;}
  const days=Math.max(1,Math.ceil((new Date(end)-new Date(start))/86400000));
  const total=car.pricePerDay*days;
  DB.bookings.push({_id:'bk'+Date.now(),customerName:name,carNumber:plate,startDate:start,endDate:end,returnDate:null,extraCharge:0,totalAmount:total});
  toast(`Đặt xe thành công! ${days} ngày — ₫${total.toLocaleString('vi-VN')}`);
  closeOv('ov-addbooking');loadBookings();loadDashboard();
}

// ══ SỬA ĐƠN ĐẶT ══
async function openEditBooking(id){
  let bk=DB.bookings.find(b=>b._id===id);
  try{const d=await apiCall('GET','/api/bookings/'+id);if(d.success)bk=d.data;}catch(e){}
  if(!bk){toast('Không tìm thấy đơn đặt','err');return;}
  document.getElementById('eb-id').value=bk._id;
  document.getElementById('eb-name').value=bk.customerName;
  document.getElementById('eb-plate').value=bk.carNumber;
  document.getElementById('eb-start').value=toLocalDT(bk.startDate);
  document.getElementById('eb-end').value=toLocalDT(bk.endDate);
  document.getElementById('eb-return').value=bk.returnDate?toLocalDT(bk.returnDate):'';
  document.getElementById('eb-latefee').value=bk.extraCharge||0;
  openOv('ov-editbooking');
}
async function updateBooking(){
  const id=v('eb-id'), name=v('eb-name').trim();
  const start=v('eb-start'), end=v('eb-end');
  const returnDate=v('eb-return'), lateFeePerDay=parseFloat(v('eb-latefee'))||0;
  if(!name){setMsg('msg-editbooking','⚠️ Vui lòng nhập tên khách hàng',false);return;}
  if(!start||!end){setMsg('msg-editbooking','⚠️ Vui lòng điền đầy đủ ngày',false);return;}
  let extraCharge=0;
  if(returnDate&&end){
    const retDT=new Date(returnDate), endDT=new Date(end);
    if(retDT>endDT){
      const lateDays=Math.ceil((retDT-endDT)/86400000);
      extraCharge=lateDays*lateFeePerDay;
    }
  }
  const bk=DB.bookings.find(b=>b._id===id)||{};
  const car=DB.cars.find(c=>c.carNumber===bk.carNumber)||{pricePerDay:0};
  const days=Math.max(1,Math.ceil((new Date(end)-new Date(start))/86400000));
  const total=car.pricePerDay*days+extraCharge;
  const data={customerName:name,startDate:new Date(start).toISOString(),endDate:new Date(end).toISOString(),
    returnDate:returnDate?new Date(returnDate).toISOString():null,extraCharge,totalAmount:total};
  try{
    const d=await apiCall('PUT','/api/bookings/'+id,data);
    if(d.success){toast('Đã cập nhật đơn đặt xe thành công');closeOv('ov-editbooking');loadBookings();loadDashboard();return;}
    setMsg('msg-editbooking','❌ '+d.message,false);return;
  }catch(e){}
  const idx=DB.bookings.findIndex(b=>b._id===id);
  if(idx>=0) DB.bookings[idx]={...DB.bookings[idx],...data};
  toast('Đã cập nhật đơn đặt xe thành công');
  closeOv('ov-editbooking');loadBookings();loadDashboard();
}

// ══ XÓA ĐƠN ĐẶT ══
async function deleteBooking(id){
  const bk=DB.bookings.find(b=>b._id===id)||{};
  const ok=await confirm2('Xóa Đơn Đặt',`Xóa đơn của "${bk.customerName}" — xe ${bk.carNumber}?`,'🗑️','Xóa','btn-danger');
  if(!ok)return;
  try{
    const d=await apiCall('DELETE','/api/bookings/'+id);
    if(d.success){toast('Đã xóa đơn đặt xe');loadBookings();loadDashboard();return;}
    toast('Lỗi: '+d.message,'err');return;
  }catch(e){}
  DB.bookings=DB.bookings.filter(b=>b._id!==id);
  toast('Đã xóa đơn đặt xe');loadBookings();loadDashboard();
}

// ══ REPORTS ══
async function loadReports(){
  const [cars,bookings]=await Promise.all([getCars(),getBookings()]);
  const avail=cars.filter(c=>c.status==='available').length;
  const rented=cars.filter(c=>c.status==='rented').length;
  const maint=cars.filter(c=>c.status==='maintenance').length;
  const total=cars.length||1;
  document.getElementById('rpt-fleet').innerHTML=
    progRow('Sẵn có',avail,total,'var(--green)')+
    progRow('Đang thuê',rented,total,'var(--orange)')+
    progRow('Bảo trì',maint,total,'var(--red)');
  const rev=bookings.reduce((s,b)=>s+(b.totalAmount||0),0);
  document.getElementById('rpt-revenue').textContent='₫'+rev.toLocaleString('vi-VN');
  const extraTotal=bookings.reduce((s,b)=>s+(b.extraCharge||0),0);
  const returned=bookings.filter(b=>b.returnDate).length;
  document.getElementById('rpt-bookings').innerHTML=`
    <div style="display:flex;flex-direction:column;gap:10px;margin-top:4px">
      ${kv('Tổng đơn đặt',bookings.length)}
      ${kv('Đã trả xe',returned,'var(--green)')}
      ${kv('Chưa trả',bookings.length-returned,'var(--orange)')}
      ${kv('Tổng phí trễ hạn','₫'+extraTotal.toLocaleString('vi-VN'),'var(--red)')}
    </div>`;
  const cnt={};
  bookings.forEach(b=>{cnt[b.carNumber]=(cnt[b.carNumber]||0)+1;});
  const sorted=Object.entries(cnt).sort((a,b)=>b[1]-a[1]).slice(0,4);
  document.getElementById('rpt-popular').innerHTML=sorted.length
    ?sorted.map(([plate,n])=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)"><span class="car-plate" style="display:inline-block">${plate}</span><span style="font-size:.82em;color:var(--muted)">${n} lần đặt</span></div>`).join('')
    :'<div style="color:var(--muted);font-size:.82em;margin-top:8px">Chưa có dữ liệu</div>';
}
function progRow(label,val,total,color){
  const pct=total?Math.round(val/total*100):0;
  return `<div class="prog-row"><span class="prog-label">${label}</span><span class="prog-val" style="color:${color}">${val} xe (${pct}%)</span></div>
    <div class="prog-bar"><div class="prog-fill" style="width:${pct}%;background:${color}"></div></div>`;
}
function kv(k,val,c=''){
  return `<div style="display:flex;justify-content:space-between"><span style="color:var(--muted);font-size:.82em">${k}</span><strong${c?` style="color:${c}"`:''}>${val}</strong></div>`;
}

// ══ UTILS ══
function fmtDate(d){return d?new Date(d).toLocaleDateString('vi-VN'):'—';}
function fmtShort(n){return n>=1e9?(n/1e9).toFixed(1)+'B':n>=1e6?(n/1e6).toFixed(1)+'M':n>=1e3?(n/1e3).toFixed(0)+'K':n.toString();}
function toLocalDT(iso){
  if(!iso)return '';
  const d=new Date(iso);
  const p=n=>String(n).padStart(2,'0');
  return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}`;
}

